{
  "name": "wdeer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A theHunter-style hunting vertical slice built with Babylon.js on WebGPU.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
