    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@babylonjs/core": "^9.12.1",
    "@babylonjs/gui": "^9.12.1",
    "@babylonjs/havok": "^1.3.12",
    "@babylonjs/loaders": "^9.12.1",
    "@babylonjs/materials": "^9.12.1"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
